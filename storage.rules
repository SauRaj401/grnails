rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow uploads to booking-specific folders (images only, <= 3MB).
    match /bookings/{bookingReference}/{fileName=**} {
      allow write: if request.resource != null
                   && request.resource.size < 3 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Booking screenshots are public for the customer who uploaded them and for admin review.
      allow read: if true;
    }

    // Deny by default for other paths.
  }
}
