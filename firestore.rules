rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Bookings collection
    match /bookings/{bookingId} {
      // Allow anyone to create a booking document, but require sensible fields.
      allow create: if request.resource.data.keys().hasAll(["reference","name","phone","services","total","createdAt"]) &&
                    request.resource.data.status == "pending" &&
                    request.resource.data.total is number &&
                    request.resource.data.services is list;

      // Only admins (custom claim `admin == true`) can read, list, update or delete bookings.
      allow read, list, update, delete: if request.auth != null && request.auth.token.admin == true;
    }

    // Deny everything else by default.
  }
}
